# Node.js environment
NODE_ENV=development

# Server port
PORT=5000

# MongoDB Connection URI
# IMPORTANT: URL-encode special chars in password (@ → %40, # → %23)
# Example: password Tushar@123 becomes Tushar%40123
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxxx.mongodb.net/empai_db?retryWrites=true&w=majority&appName=Cluster0

# JWT Configuration — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long
JWT_EXPIRES_IN=7d

# OpenRouter API (Get free key at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Frontend URL (for CORS) — update with your Vercel URL in production
FRONTEND_URL=http://localhost:5173
