# Node.js environment
NODE_ENV=development

# Server port
PORT=5000

# MongoDB Connection URI
# Replace with your actual MongoDB Atlas URI or local URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/empai_db?retryWrites=true&w=majority
# Local: MONGODB_URI=mongodb://localhost:27017/empai_db

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_this_in_production
JWT_EXPIRES_IN=7d

# OpenRouter API (Get free key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
